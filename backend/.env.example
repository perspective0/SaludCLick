# Database
DATABASE_URL=postgresql://user:password@localhost:5432/saludclick
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saludclick
DB_USER=postgres
DB_PASSWORD=password

# JWT
JWT_SECRET=tu_super_secreto_jwt_aqui_cambiar_en_produccion
JWT_EXPIRE=7d

# Server
PORT=5000
NODE_ENV=development

# Frontend
FRONTEND_URL=http://localhost:3000

# Public frontend URL used in prescription QR codes. Never use localhost in production.
PUBLIC_APP_URL=https://saludclick.app

# Jitsi/JaaS (opcional, requerido para asegurar moderador por JWT)
# Para 8x8 JaaS usa JITSI_DOMAIN=8x8.vc y NEXT_PUBLIC_JITSI_DOMAIN=8x8.vc en frontend.
JITSI_DOMAIN=meet.jit.si
JITSI_APP_ID=tu_app_id_de_jitsi
JITSI_JWT_SECRET=tu_secret_jwt_de_jitsi
JITSI_JWT_AUD=jitsi

# Email (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_contraseña_app
SMTP_ADMIN=admin@saludclick.com
SMTP_FROM=SaludClick <no-reply@saludclick.com>

# WhatsApp Cloud API (modo prueba)
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=pega_aqui_tu_token_temporal_de_meta
WHATSAPP_PHONE_NUMBER_ID=1112700668602301
WHATSAPP_BUSINESS_ACCOUNT_ID=983393098015867
WHATSAPP_API_VERSION=v25.0
WHATSAPP_TEST_RECIPIENT=18091234567

# Telegram admin notifications (opcional, backend only)
TELEGRAM_BOT_TOKEN=
TELEGRAM_DOCTOR_REQUESTS_CHAT_ID=

# Stripe (opcional)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_DOCTOR_PRICE_ID=price_xxx

# Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
